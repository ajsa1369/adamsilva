# ============================================================
# Phase 4: Agentic Intake Agent — Required Environment Variables
# Copy this file to .env.local and fill in values.
# ============================================================

# --- Supabase (already set from earlier phases) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # needed for server-side proposal inserts

# --- AI Provider (INTAKE-09: never hardcode — use MODEL_PROVIDER) ---
MODEL_PROVIDER=google                               # default: 'google' (free tier). Options: 'google' | 'anthropic' | 'openai'
GOOGLE_GENERATIVE_AI_API_KEY=AIza...               # required if MODEL_PROVIDER=google (default)
ANTHROPIC_API_KEY=sk-ant-...                        # required if MODEL_PROVIDER=anthropic
OPENAI_API_KEY=sk-...                               # required if MODEL_PROVIDER=openai

# --- Email Delivery (Supabase edge functions use Resend; Next.js routes use SMTP) ---
RESEND_API_KEY=re_...                               # Resend.com — used by send-proposal-email Supabase edge function

# --- SMTP (hosting.com — used by authority-map routes) ---
SMTP_HOST=mail.adamsilvaconsulting.com             # Your hosting.com mail server (e.g. mail.yourdomain.com)
SMTP_PORT=465                                      # 465 = SSL, 587 = STARTTLS
SMTP_USER=info@adamsilvaconsulting.com             # Full email address (SMTP login)
SMTP_PASS=your-email-password                      # Email account password
# SMTP_FROM=Adam Silva Consulting <info@adamsilvaconsulting.com>  # Optional: overrides default From header

# --- CRM Integration (INTAKE-07) ---
ASC_CRM_WEBHOOK_URL=https://your-crm.com/webhook   # POST target for new deals
ASC_CRM_API_KEY=your-crm-bearer-token              # CRM webhook auth token

# --- Site URL (used in PDF and email links) ---
NEXT_PUBLIC_SITE_URL=https://www.adamsilvaconsulting.com

# --- Cron Security (INTAKE-08 follow-up) ---
CRON_SECRET=generate-a-random-secret               # Vercel auto-injects this for cron routes

# Phase 5 — Topical Authority Map Agent
AUTHORITY_MAP_CLIENTS=             # JSON array: [{"clientId":"client-1","industry":"HVAC","serviceArea":"Atlanta, GA","approvalEmail":"client@example.com"}]
# NOTEBOOKLM_MCP_URL=              # Optional: HTTP(S) URL of NotebookLM MCP server (SSE transport). If set, uses NotebookLM for deep research instead of Gemini fallback.

# === Phase 6: Blog Post Production Pipeline ===
STRAPI_URL=https://cms.adamsilvaconsulting.com
STRAPI_API_TOKEN=                # Required: create in Strapi admin > Settings > API Tokens
INSIGHTS_CLIENTS=[{"clientId":"client-1","authorName":"Adam Silva","approvalEmail":"client@example.com"}]  # JSON array of BlogClientConfig
INSIGHTS_IMAGES_BASE_URL=https://www.adamsilvaconsulting.com/images/insights  # Base URL for ImageObject contentUrl in JSON-LD

# === Phase 7: Press Release Engine ===
# Wire service API keys — only set the services you have accounts for
# Default wire service: EIN Presswire (free tier)
EINPRESSWIRE_API_KEY=            # Required for EIN Presswire distribution (default)
BUSINESSWIRE_API_KEY=            # Optional: Business Wire distribution
PRNEWSWIRE_API_KEY=              # Optional: PR Newswire distribution
ACCESSWIRE_API_KEY=              # Optional: AccessWire distribution
# NotebookLM MCP (optional) — if set, researcher uses NotebookLM for topic context
# NOTEBOOKLM_MCP_URL=           # Already documented in Phase 5 block — shared env var
